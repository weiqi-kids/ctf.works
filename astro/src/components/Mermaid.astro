---
// 靜態結構圖：mermaid（client-side 渲染，CDN ESM）。
// 用於首頁工坊主迴圈拓樸 / 流程 sequence。
interface Props {
  chart: string;
  id?: string;
}
const { chart, id = 'mmd-' + Math.random().toString(36).slice(2, 9) } = Astro.props;
---

<div class="mermaid-box">
  <pre class="mermaid-src" data-mermaid-id={id} style="display:none">{chart}</pre>
  <div class="mermaid-out" id={id}></div>
</div>

<script>
  import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

  // 色彩值 = design-tokens colors.md 的 hex fallback（Mermaid 不支援 oklch）
  // useMaxWidth:false → 圖以原生尺寸渲染，文字嚴格維持 20px 不被容器縮放
  //（窄畫面由 .mermaid-box 的 overflow-x:auto 提供水平捲動）。
  mermaid.initialize({
    startOnLoad: false,
    theme: 'base',
    flowchart: { useMaxWidth: false },
    sequence: { useMaxWidth: false },
    themeVariables: {
      darkMode: false,
      background: '#ecedf0',
      primaryColor: '#ecedf0',
      primaryBorderColor: '#d5d6da',
      primaryTextColor: '#1e2030',
      lineColor: '#8a8c98',
      secondaryColor: '#fceee8',
      tertiaryColor: '#ecedf0',
      fontFamily:
        "ui-monospace, 'SF Mono', Menlo, Consolas, monospace",
      fontSize: '20px',
      actorBorder: '#b86a2a',
      actorBkg: '#ecedf0',
      actorTextColor: '#1e2030',
      signalColor: '#5e6070',
      signalTextColor: '#5e6070',
    },
  });

  async function render() {
    const blocks = document.querySelectorAll<HTMLElement>('.mermaid-src');
    for (const block of blocks) {
      const id = block.getAttribute('data-mermaid-id')!;
      const out = document.getElementById(id);
      if (!out || out.dataset.done) continue;
      try {
        const { svg } = await mermaid.render(id + '-svg', block.textContent || '');
        out.innerHTML = svg;
        out.dataset.done = '1';
      } catch (err) {
        out.innerHTML =
          '<pre style="color:#c93135;font-size:1.125rem">mermaid render error</pre>';
        console.error(err);
      }
    }
  }
  render();
</script>
