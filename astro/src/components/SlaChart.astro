---
// SLA / 守住率 over rounds（d3）— /evidence/ 用。
// 從某 run 的 timeseries 算每 round 的守住率與 SLA。
import type { Run } from '../lib/data';
interface Props {
  run: Run;
}
const { run } = Astro.props;
const payload = JSON.stringify(run.timeseries ?? []);
---

<div class="sla" data-sla>
  <script type="application/json" data-sla-data set:html={payload} />
  <svg data-sla-svg class="sla-svg"></svg>
  <div class="sla-legend mono faint">
    <span><i class="dot dot-held"></i>守住率</span>
    <span><i class="dot dot-sla"></i>SLA</span>
    <span><i class="dot dot-stolen"></i>被偷 round</span>
  </div>
</div>

<style>
  .sla-svg {
    width: 100%;
    height: 180px;
    display: block;
  }
  .sla-legend {
    display: flex;
    gap: 1.2rem;
    font-size: var(--text-xs);
    margin-top: 0.5rem;
  }
  .sla-legend span {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }
  .dot-held {
    background: var(--color-pass);
  }
  .dot-sla {
    background: var(--color-accent);
  }
  .dot-stolen {
    background: var(--color-critical);
  }
</style>

<script>
  import { scaleLinear } from 'd3-scale';
  import { select } from 'd3-selection';
  import { line, area } from 'd3-shape';
  import { extent } from 'd3-array';

  interface Cell {
    team: string;
    status: string;
    stolen: boolean;
  }
  interface Round {
    round: number;
    board: Cell[];
  }

  function expand(ts: Round[]): Round[] {
    if (!ts.length) return [];
    const sorted = [...ts].sort((a, b) => a.round - b.round);
    const byRound = new Map(sorted.map((r) => [r.round, r]));
    const out: Round[] = [];
    let last = sorted[0].board;
    for (let r = sorted[0].round; r <= sorted[sorted.length - 1].round; r++) {
      const kf = byRound.get(r);
      if (kf) last = kf.board;
      out.push({ round: r, board: last });
    }
    return out;
  }

  function initSla(root: HTMLElement) {
    const dataEl = root.querySelector<HTMLElement>('[data-sla-data]');
    const svgEl = root.querySelector<SVGSVGElement>('[data-sla-svg]');
    if (!dataEl || !svgEl) return;
    const ts: Round[] = JSON.parse(dataEl.textContent || '[]');
    const frames = expand(ts);
    // 字級嚴格 18px（design-tokens --text-xs，無例外）。
    const FONT = 'ui-monospace, SF Mono, Menlo, monospace';
    const FS = 18;
    if (frames.length < 2) {
      svgEl.innerHTML = `<text x="10" y="28" fill="#5e6070" font-size="${FS}" font-family="${FONT}">資料點不足以繪圖</text>`;
      return;
    }

    const data = frames.map((f) => {
      const def = f.board.filter((c) => c.team === 'defense');
      const held = def.length ? def.filter((c) => !c.stolen).length / def.length : 1;
      const sla = def.length
        ? def.filter((c) => c.status === 'OK').length / def.length
        : 1;
      const stolen = def.some((c) => c.stolen);
      return { round: f.round, held, sla, stolen };
    });

    const H = 180,
      m = { t: 16, r: 16, b: 28, l: 56 };

    // viewBox 寬 = 實測像素寬（floor，使 viewBox ≤ 實寬 → 縮放比 ≥ 1
    // → font-size 18 渲染恆 ≥ 18px，無例外）。高度固定對齊 CSS 的 180px。
    function draw() {
      const W = Math.floor(svgEl!.getBoundingClientRect().width) || 720;
      svgEl!.setAttribute('viewBox', `0 0 ${W} ${H}`);
      const svg = select(svgEl!);
      svg.selectAll('*').remove();

      const x = scaleLinear()
        .domain(extent(data, (d) => d.round) as [number, number])
        .range([m.l, W - m.r]);
      const y = scaleLinear().domain([0, 1]).range([H - m.b, m.t]);

      // 格線與軸標籤（色彩 = design-tokens hex fallback）
      [0, 0.5, 1].forEach((t) => {
        svg
          .append('line')
          .attr('x1', m.l)
          .attr('x2', W - m.r)
          .attr('y1', y(t))
          .attr('y2', y(t))
          .attr('stroke', '#d5d6da');
        svg
          .append('text')
          .attr('x', m.l - 10)
          .attr('y', y(t) + FS * 0.35)
          .attr('text-anchor', 'end')
          .attr('fill', '#5e6070')
          .attr('font-size', FS)
          .attr('font-family', FONT)
          .text(`${Math.round(t * 100)}%`);
      });

      const heldArea = area<(typeof data)[0]>()
        .x((d) => x(d.round))
        .y0(H - m.b)
        .y1((d) => y(d.held));
      svg
        .append('path')
        .attr('d', heldArea(data) || '')
        .attr('fill', 'rgba(30,128,80,0.10)');

      const mk = (key: 'held' | 'sla', color: string, dash?: string) => {
        const ln = line<(typeof data)[0]>()
          .x((d) => x(d.round))
          .y((d) => y(d[key]));
        const p = svg
          .append('path')
          .attr('d', ln(data) || '')
          .attr('fill', 'none')
          .attr('stroke', color)
          .attr('stroke-width', 2);
        if (dash) p.attr('stroke-dasharray', dash);
      };
      mk('held', '#1e8050');
      mk('sla', '#b86a2a', '4 3');

      // 被偷 round 標記
      data
        .filter((d) => d.stolen)
        .forEach((d) => {
          svg
            .append('circle')
            .attr('cx', x(d.round))
            .attr('cy', y(d.held))
            .attr('r', 4)
            .attr('fill', '#c93135')
            .attr('stroke', '#f5f6f8')
            .attr('stroke-width', 1.5)
            .append('title')
            .text(`round ${d.round}：被偷`);
        });
    }

    draw();
    // 容器寬度變動時重畫，維持 1:1 像素比例。
    if (typeof ResizeObserver !== 'undefined') {
      new ResizeObserver(() => draw()).observe(svgEl);
    } else {
      window.addEventListener('resize', draw);
    }
  }

  document
    .querySelectorAll<HTMLElement>('[data-sla]')
    .forEach((el) => initSla(el));
</script>
