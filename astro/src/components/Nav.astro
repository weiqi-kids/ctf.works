---
const base = import.meta.env.BASE_URL;
const u = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
const { active } = Astro.props as { active?: string };

const links = [
  { href: u('/recipe/'), label: '配方', key: 'recipe', primary: true },
  { href: u('/runs/'), label: '歷史', key: 'runs' },
  { href: u('/evidence/'), label: '證據', key: 'evidence' },
  { href: u('/attack/'), label: '攻擊情報', key: 'attack' },
];
---

<header class="site-nav">
  <div class="wrap nav-inner">
    <a class="brand" href={u('/')}>
      <span class="brand-mark">⚒</span>
      <span class="brand-text">FORGE</span>
      <span class="brand-sub">攻防工坊</span>
    </a>
    <nav class="nav-links">
      {
        links.map((l) => (
          <a
            href={l.href}
            class={`nav-link${active === l.key ? ' is-active' : ''}${
              l.primary ? ' is-primary' : ''
            }`}
          >
            {l.label}
          </a>
        ))
      }
      <a
        class="nav-link nav-github"
        href="https://github.com/weiqi-kids/ctf.works"
        target="_blank"
        rel="noreferrer"
      >
        GitHub ↗
      </a>
    </nav>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background: rgba(10, 11, 13, 0.82);
    border-bottom: 1px solid var(--c-slate);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    gap: 1rem;
  }
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-mono);
  }
  .brand-mark {
    color: var(--c-ember);
    font-size: 1.3rem;
    transform: translateY(2px);
    filter: drop-shadow(0 0 8px rgba(255, 90, 31, 0.5));
  }
  .brand-text {
    font-weight: 800;
    letter-spacing: 0.18em;
    font-size: 1.05rem;
    color: var(--c-bone);
  }
  .brand-sub {
    font-size: 0.72rem;
    color: var(--c-faint);
    letter-spacing: 0.1em;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }
  .nav-link {
    padding: 0.4rem 0.7rem;
    border-radius: 2px;
    color: var(--c-mist);
    transition: all 0.15s;
    position: relative;
  }
  .nav-link:hover {
    color: var(--c-bone);
    background: var(--c-steel);
  }
  .nav-link.is-active {
    color: var(--c-ember-bright);
  }
  .nav-link.is-active::after {
    content: '';
    position: absolute;
    left: 0.7rem;
    right: 0.7rem;
    bottom: -2px;
    height: 2px;
    background: var(--c-ember);
  }
  .nav-link.is-primary {
    color: var(--c-bone);
  }
  .nav-link.is-primary::before {
    content: '◆';
    font-size: 0.55em;
    color: var(--c-ember);
    margin-right: 0.35rem;
    vertical-align: middle;
  }
  .nav-github {
    color: var(--c-faint);
  }
  @media (max-width: 680px) {
    .brand-sub {
      display: none;
    }
    .nav-links {
      gap: 0.1rem;
      font-size: 0.74rem;
    }
    .nav-link {
      padding: 0.35rem 0.45rem;
    }
    .nav-github {
      display: none;
    }
  }
</style>
