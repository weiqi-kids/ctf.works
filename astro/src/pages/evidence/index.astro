---
import Layout from '../../layouts/Layout.astro';
import SlaChart from '../../components/SlaChart.astro';
import { getRuns, modelLabel, pct, SERVICES, serviceLabel } from '../../lib/data';

const base = import.meta.env.BASE_URL;
const u = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;

const runs = getRuns();
const normalRuns = runs.filter((r) => r.kind !== 'portability');
const portRuns = runs.filter((r) => r.kind === 'portability');

// 主成效 run（最新 normal）
const mainRun = normalRuns[0] ?? runs[0];

// 補丁成效（最新 run 的 patch_effective）
const patches = mainRun?.defense.patch_effective ?? {};

// 不補基線對照：守住 run vs baseline lost
const baselineCmp = runs.map((r) => ({
  run_id: r.run_id,
  held: r.defense.flags_held_pct,
  baselineLost: r.defense.nopatch_baseline_flags_lost ?? 0,
  selfOwn: r.defense.self_own_count ?? 0,
  kind: r.kind ?? 'normal',
}));

const totalBaselineLost = baselineCmp.reduce(
  (s, r) => s + r.baselineLost,
  0,
);
---

<Layout title="信任證據 — FORGE ⚒ 攻防工坊" active="evidence">
  <section class="wrap ev-page">
    <div class="page-head rise">
      <span class="kicker">信任證據 · WHY ADOPT</span>
      <h1 class="page-title">為什麼值得採用</h1>
      <p class="muted page-lead">
        守住率、SLA over rounds、不補基線對照、可攜性。配方不是說漂亮話,是在攻擊下守得住的數據。
      </p>
    </div>

    <!-- 頂部三大指標 -->
    <div class="ev-hero rise">
      <div class="ev-metric card corner-marks">
        <span class="metric-val is-ember">{pct(mainRun.defense.flags_held_pct)}</span>
        <span class="metric-label">守住率（最新場）</span>
        <p class="ev-m-note faint mono">{mainRun.run_id}</p>
      </div>
      <div class="ev-metric card corner-marks">
        <span class="metric-val">{pct(mainRun.defense.sla_uptime_pct)}</span>
        <span class="metric-label">SLA 正常運行</span>
        <p class="ev-m-note faint mono">補洞不破壞合法功能</p>
      </div>
      <div class="ev-metric card corner-marks">
        <span class="metric-val stolen-val">{totalBaselineLost}</span>
        <span class="metric-label">基線總丟旗（不補對照）</span>
        <p class="ev-m-note faint mono">同攻擊下、不補的下場</p>
      </div>
    </div>

    <!-- SLA over rounds -->
    <div class="card ev-block corner-marks rise">
      <div class="block-head">
        <span class="kicker">守住率 / SLA over rounds</span>
        <span class="mono faint">{mainRun.run_id}</span>
      </div>
      <SlaChart run={mainRun} />
    </div>

    <!-- 修補成效 + 不補基線對照 -->
    <div class="ev-two">
      <div class="card ev-block corner-marks rise">
        <span class="kicker">修補成效 · 逐服務</span>
        <p class="muted ev-sub">每洞補丁是否真的擋住（改完跑 exploit 驗證）</p>
        <table class="grid">
          <thead>
            <tr>
              <th>服務</th>
              <th>漏洞</th>
              <th>補丁有效</th>
            </tr>
          </thead>
          <tbody>
            {
              SERVICES.map((s) => {
                const ok = patches[s];
                const vuln =
                  s === 'notes'
                    ? 'IDOR'
                    : s === 'filelocker'
                      ? 'path traversal'
                      : 'OOB read';
                return (
                  <tr>
                    <td class="mono">{serviceLabel(s)}</td>
                    <td class="muted">{vuln}</td>
                    <td>
                      {ok === undefined ? (
                        <span class="faint mono">—</span>
                      ) : ok ? (
                        <span class="tag tag-hold mono">✓ 擋住</span>
                      ) : (
                        <span class="tag mono stolen-tag">✗ 未擋</span>
                      )}
                    </td>
                  </tr>
                );
              })
            }
          </tbody>
        </table>
      </div>

      <div class="card ev-block corner-marks rise">
        <span class="kicker">不補基線對照 · 自殘</span>
        <p class="muted ev-sub">配方守住 vs 同場「不補」基線丟旗;自殘 = 補丁誤傷合法功能</p>
        <table class="grid">
          <thead>
            <tr>
              <th>run</th>
              <th>守住率</th>
              <th>基線丟旗</th>
              <th>自殘</th>
            </tr>
          </thead>
          <tbody>
            {
              baselineCmp.map((r) => (
                <tr>
                  <td class="mono">
                    <a class="ev-runlink" href={u(`/runs/${r.run_id}/`)}>
                      {r.run_id}
                    </a>
                  </td>
                  <td class="ember mono">{pct(r.held)}</td>
                  <td class="stolen-val mono">{r.baselineLost}</td>
                  <td class="mono">{r.selfOwn}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>

    <!-- 可攜性 -->
    <div class="card ev-block corner-marks rise">
      <div class="block-head">
        <span class="kicker">可攜性 · 搬乾淨主機仍守得住</span>
      </div>
      {
        portRuns.length === 0 ? (
          <p class="muted">尚無可攜性場次。</p>
        ) : (
          <div class="port-grid">
            {portRuns.map((r) => (
              <a class="port-card" href={u(`/runs/${r.run_id}/`)}>
                <div class="pc-head mono">
                  <span class="tag tag-ember">portability</span>
                  <span class="pc-id">{r.run_id}</span>
                </div>
                <p class="muted pc-desc">
                  乾淨黃金映像({r.fingerprint.image_hash})上重跑同配方,
                  驗證不是靠殘留狀態守住。
                </p>
                <div class="pc-metrics">
                  <span>
                    <b class="ember mono">{pct(r.defense.flags_held_pct)}</b>
                    <small class="faint"> 守住率</small>
                  </span>
                  <span>
                    <b class="mono">{pct(r.defense.sla_uptime_pct)}</b>
                    <small class="faint"> SLA</small>
                  </span>
                </div>
                <span class="pc-go ember mono">看回放 →</span>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <style>
    .ev-page {
      padding-top: clamp(2rem, 5vw, 3.5rem);
    }
    .page-head {
      margin-bottom: 1.8rem;
    }
    .page-title {
      font-size: clamp(1.8rem, 4.5vw, 2.8rem);
      margin: 0.6rem 0 0.8rem;
    }
    .page-lead {
      max-width: 640px;
    }
    .stolen-val {
      color: var(--c-stolen);
    }
    .ember {
      color: var(--c-ember-bright);
    }

    .ev-hero {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.1rem;
      margin-bottom: 1.2rem;
    }
    .ev-metric {
      padding: 1.3rem;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .ev-m-note {
      font-size: 0.7rem;
      margin-top: 0.3rem;
    }

    .ev-block {
      padding: 1.3rem;
      margin-bottom: 1.2rem;
    }
    .block-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .ev-sub {
      font-size: 0.82rem;
      margin: 0.5rem 0 1rem;
    }
    .ev-two {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 1.1rem;
    }
    .stolen-tag {
      color: var(--c-stolen);
      border-color: #5c1e2b;
      background: #2a0d14;
    }
    .ev-runlink {
      color: var(--c-mist);
    }
    .ev-runlink:hover {
      color: var(--c-ember-bright);
    }

    .port-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1rem;
    }
    .port-card {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      padding: 1.1rem;
      border: 1px solid var(--c-slate);
      border-radius: var(--radius);
      background: var(--c-iron);
      transition: all 0.18s;
    }
    .port-card:hover {
      border-color: var(--c-ember);
      transform: translateY(-2px);
    }
    .pc-head {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.84rem;
    }
    .pc-id {
      color: var(--c-bone);
      font-weight: 600;
    }
    .pc-desc {
      font-size: 0.8rem;
    }
    .pc-metrics {
      display: flex;
      gap: 1.5rem;
      padding: 0.5rem 0;
      border-top: 1px solid var(--c-slate);
    }
    .pc-metrics b {
      font-size: 1.1rem;
    }
    .pc-go {
      font-size: 0.78rem;
    }

    @media (max-width: 820px) {
      .ev-hero {
        grid-template-columns: 1fr;
      }
      .ev-two {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
